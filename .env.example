PORT=3001

# Same MySQL/MariaDB as Laravel
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=db_traceability

# Where uploaded files go. Should match Laravel's storage/app/public/proofs
# so files are accessible from both stacks.
UPLOAD_PATH=./storage/proofs
PUBLIC_UPLOAD_BASE=/storage/proofs
